// Prisma schema for the PR-Agent SaaS foundation.
// Multi-tenant: every tenant-owned record carries an organizationId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

// Generic low/medium/high rating reused across the PR workflow.
enum Level {
  LOW
  MEDIUM
  HIGH
}

// Extended outreach lifecycle covering the full pitch-to-publish process.
enum OutreachStatus {
  DRAFT
  READY
  SENT
  FOLLOW_UP_DUE
  INTERESTED
  ACCEPTED
  DECLINED
  ARTICLE_DELIVERED
  PUBLISHED
}

enum RawInputSourceType {
  NOTE
  WEBSITE
  TRANSCRIPT
  EMAIL
  BRIEFING
  SOCIAL
  PRESSKIT
  OTHER
}

enum RawInputStatus {
  NEW
  PROCESSED
  NEEDS_REVIEW
  ARCHIVED
}

enum InsightType {
  POSITIONING
  EXPERTISE
  TARGET_GROUP
  PROOF_POINT
  QUOTE
  TOPIC_FIELD
  NO_GO
  RISK
  MISSING_INFO
  MEDIA_ANGLE
}

enum InsightStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum TopicStatus {
  DRAFT
  APPROVED
  PITCHED
  ARCHIVED
}

enum BriefingStatus {
  DRAFT
  APPROVED
  DELIVERED
}

enum ArticleStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
  PUBLISHED
  ARCHIVED
}

enum KnowledgeCategory {
  POSITIONING
  EXPERTISE
  TARGET_GROUP
  PROOF_POINT
  QUOTE
  REFERENCE
  TOPIC_FIELD
  MEDIA_ANGLE
  NO_GO
  RISK
  FAQ
  COMPETITOR
  OTHER
}

// ----------------------------------------------------------------------------
// Tenancy
// ----------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  clients        Client[]
  campaigns      Campaign[]
  mediaContacts  MediaContact[]
  outreaches     Outreach[]
  rawInputs      ClientRawInput[]
  insights       ClientInsight[]
  topicIdeas     TopicIdea[]
  briefings      Briefing[]
  articleDrafts  ArticleDraft[]
  publications   Publication[]
  writingRuleSets WritingRuleSet[]
  knowledge       ClientKnowledge[]
  knowledgeNodes  KnowledgeNode[]
  knowledgeEdges  KnowledgeEdge[]
  aiUsageLogs     AIUsageLog[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           Role     @default(VIEWER)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rawInputs    ClientRawInput[]
  aiUsageLogs  AIUsageLog[]

  @@index([organizationId])
}

// ----------------------------------------------------------------------------
// Core domain models — all scoped by organizationId
// ----------------------------------------------------------------------------

model Client {
  id             String   @id @default(cuid())
  name           String
  contactEmail   String?
  contactPhone   String?
  website        String?
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]
  rawInputs     ClientRawInput[]
  insights      ClientInsight[]
  topicIdeas    TopicIdea[]
  briefings     Briefing[]
  articleDrafts ArticleDraft[]
  publications  Publication[]
  knowledge      ClientKnowledge[]
  knowledgeNodes KnowledgeNode[]
  knowledgeEdges KnowledgeEdge[]

  @@index([organizationId])
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  description    String?
  status         CampaignStatus @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  clientId       String
  organizationId String
  // External read-only report sharing.
  shareToken     String?        @unique
  shareEnabled   Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  outreaches    Outreach[]
  topicIdeas    TopicIdea[]
  briefings     Briefing[]
  articleDrafts ArticleDraft[]
  publications  Publication[]

  @@index([organizationId])
  @@index([clientId])
}

model MediaContact {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  phone          String?
  outlet         String?
  beat           String?
  notes          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outreaches   Outreach[]
  briefings    Briefing[]
  publications Publication[]

  @@index([organizationId])
}

model Outreach {
  id             String         @id @default(cuid())
  subject        String
  message        String?
  status         OutreachStatus @default(DRAFT)
  sentAt         DateTime?
  // Extended PR-process fields.
  pitchEmail        String?
  followUpEmail     String?
  lastContactDate   DateTime?
  nextFollowUpDate  DateTime?
  agreedTopic       String?
  publicationUrl    String?
  internalNotes     String?
  campaignId     String
  mediaContactId String
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  mediaContact MediaContact @relation(fields: [mediaContactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
  @@index([mediaContactId])
}

// ----------------------------------------------------------------------------
// PR workflow models
// ----------------------------------------------------------------------------

// 1. Client intake — any unstructured information about a client.
model ClientRawInput {
  id             String             @id @default(cuid())
  title          String
  sourceType     RawInputSourceType @default(NOTE)
  rawText        String?
  fileName       String?
  status         RawInputStatus     @default(NEW)
  clientId       String
  createdById    String?
  organizationId String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([clientId])
}

// 2. Structured insights derived from raw input.
model ClientInsight {
  id             String        @id @default(cuid())
  insightType    InsightType
  title          String
  content        String?
  confidence     Int           @default(50) // 0-100
  status         InsightStatus @default(DRAFT)
  clientId       String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
}

// 3. Topic ideas / story angles.
model TopicIdea {
  id              String      @id @default(cuid())
  title           String
  description     String?
  mediaAngle      String?
  targetMediaType String?
  searchPotential Level       @default(MEDIUM)
  newsValue       Level       @default(MEDIUM)
  priority        Level       @default(MEDIUM)
  status          TopicStatus @default(DRAFT)
  clientId        String
  campaignId      String?
  organizationId  String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  briefings    Briefing[]

  @@index([organizationId])
  @@index([clientId])
  @@index([campaignId])
}

// 4. Briefings for a pitch / article.
model Briefing {
  id                String         @id @default(cuid())
  title             String
  targetAudience    String?
  angle             String?
  keyMessages       String?
  suggestedStructure String?
  expertContext     String?
  noGos             String?
  status            BriefingStatus @default(DRAFT)
  clientId          String
  campaignId        String?
  topicIdeaId       String?
  mediaContactId    String?
  organizationId    String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  topicIdea    TopicIdea?    @relation(fields: [topicIdeaId], references: [id], onDelete: SetNull)
  mediaContact MediaContact? @relation(fields: [mediaContactId], references: [id], onDelete: SetNull)
  articleDrafts ArticleDraft[]

  @@index([organizationId])
  @@index([clientId])
  @@index([campaignId])
}

// 5. Article drafts.
model ArticleDraft {
  id              String        @id @default(cuid())
  title           String
  subtitle        String?
  articleText     String?
  metaDescription String?
  targetMedium    String?
  targetAudience  String?
  status          ArticleStatus @default(DRAFT)
  qualityNotes    String?
  clientId        String
  campaignId      String?
  briefingId      String?
  organizationId  String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  briefing     Briefing?    @relation(fields: [briefingId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([clientId])
  @@index([campaignId])
}

// 6. Publications (placed coverage).
model Publication {
  id              String    @id @default(cuid())
  title           String
  url             String?
  publicationDate DateTime?
  notes           String?
  clientId        String
  campaignId      String?
  mediaContactId  String?
  organizationId  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  mediaContact MediaContact? @relation(fields: [mediaContactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([clientId])
  @@index([campaignId])
}

// 10. Writing rule sets used to constrain article generation later.
model WritingRuleSet {
  id                String   @id @default(cuid())
  name              String
  description       String?
  rules             String?
  forbiddenPhrases  String[] @default([])
  preferredStructure String?
  toneOfVoice       String?
  minWords          Int?
  maxWords          Int?
  organizationId    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ----------------------------------------------------------------------------
// Knowledge layer & graph (KI-gestützt)
// ----------------------------------------------------------------------------

// Central, consolidated knowledge about a client — built (later via AI) by
// merging information across multiple raw inputs. `sourceIds` references the
// ClientRawInput records the entry was derived from.
model ClientKnowledge {
  id             String            @id @default(cuid())
  category       KnowledgeCategory
  title          String
  content        String?
  confidence     Int               @default(50) // 0-100
  sourceIds      String[]          @default([])
  clientId       String
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
}

// Knowledge graph (prepared): nodes (concepts) and edges (relations) so the
// system can later merge information into connected insights.
model KnowledgeNode {
  id             String   @id @default(cuid())
  type           String // e.g. "topicField", "expertise", "mediaAngle"
  label          String
  description    String?
  clientId       String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  outgoing     KnowledgeEdge[] @relation("EdgeFrom")
  incoming     KnowledgeEdge[] @relation("EdgeTo")

  @@index([organizationId])
  @@index([clientId])
}

model KnowledgeEdge {
  id             String   @id @default(cuid())
  relation       String // e.g. "supports", "relatesTo", "derivedFrom"
  fromNodeId     String
  toNodeId       String
  clientId       String
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fromNode     KnowledgeNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode       KnowledgeNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
}

// ----------------------------------------------------------------------------
// AI usage logging
// ----------------------------------------------------------------------------

model AIUsageLog {
  id             String   @id @default(cuid())
  agent          String // agent name, e.g. "topicAgent"
  provider       String // "mock" | "anthropic" | "openai" | "local"
  mode           String // "mock" | "real"
  model          String?
  inputTokens    Int?
  outputTokens   Int?
  latencyMs      Int?
  success        Boolean  @default(true)
  error          String?
  userId         String?
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdAt])
}
