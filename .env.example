# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pr_agent?schema=public"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# Base URL of the app (used by Auth.js)
AUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# AI layer — Mock Mode by default (no external calls, no key needed).
# Switch to real AI by setting AI_MODE=real and providing a key.
# ----------------------------------------------------------------------------
AI_MODE="mock"                 # mock | real
AI_PROVIDER="anthropic"        # anthropic | openai | local
# AI_MODEL="claude-opus-4-8"   # optional model override

# Provider credentials (only needed when AI_MODE=real)
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# Local OpenAI-compatible endpoint (Ollama, vLLM, LM Studio, …)
# AI_LOCAL_BASE_URL="http://localhost:11434/v1"
# AI_LOCAL_API_KEY="local"
